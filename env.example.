# URL de tu app en Vercel (se genera después del deploy)
PUBLIC_BASE=https://tu-proyecto-xxxxx.vercel.app

# Token secreto (genera con: openssl rand -hex 32)
HOOK_TOKEN=tu_hook_token_aqui

# Discord Bot Token (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=tu_bot_token_aqui

# Discord Webhook (Servidor Discord → Integraciones → Webhooks)
DISCORD_WEBHOOK=https://discord.com/api/webhooks/ID/TOKEN

# Opcional
INTERSTITIAL_DELAY=5
APPEND_WHITELIST=github.com,example.com
