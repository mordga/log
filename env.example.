# ✅ CONFIGURACIÓN PARA VERCEL

# URL pública (Vercel te la genera después del deploy)
# Ej: https://mi-logger.vercel.app
PUBLIC_BASE=https://tu-proyecto-name.vercel.app

# Token secreto para autenticar /convert
# Genera con: openssl rand -hex 32
HOOK_TOKEN=tu_hook_token_secreto_aqui

# Discord Bot Token (para ejecutar bot.py localmente)
# Obtén en: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=tu_discord_bot_token_aqui

# Discord Webhook (para notificaciones)
# Obtén en: Servidor Discord → Integraciones → Webhooks
DISCORD_WEBHOOK=https://discord.com/api/webhooks/ID/TOKEN

# Configuración opcional
INTERSTITIAL_DELAY=5
APPEND_WHITELIST=github.com,example.com
PORT=5000
